---
<section class="card-grid-2">
  <div class="card">
    <h3 class="card-title">At a glance</h3>
    <p class="card-sub">
      Track record across four employers — government portals,
      marketplaces, and financial information services.
    </p>

    <div class="mini-grid">
      {stats.map((s) => (
        <div class={`mini${s.accent ? ' accent' : ''}`}>
          <span class="label">{s.label}</span>
          <div class="num">{s.num}</div>
          <div class="note">{s.note}</div>
        </div>
      ))}
    </div>
  </div>

  <div class="card">
    <h3 class="card-title">Get in touch</h3>
    <p class="card-sub">
      Best channel is email. Reply within a day or two.
      Open to interesting frontend work — say hello.
    </p>

    <div class="contact-list">
      {contacts.map((c) => (
        <a
          class="contact-row"
          href={c.href}
          target={c.external ? '_blank' : undefined}
          rel={c.external ? 'noopener noreferrer' : undefined}
          aria-label={c.external ? `${c.label}: ${c.value} (opens in new tab)` : `${c.label}: ${c.value}`}
        >
          <span class="ic" aria-hidden="true" set:html={c.icon} />
          <div class="meta" aria-hidden="true">
            <span class="l">{c.label}</span>
            <span class="v">{c.value}</span>
          </div>
          <span class="arrow" aria-hidden="true">↗</span>
        </a>
      ))}
    </div>
  </div>
</section>
