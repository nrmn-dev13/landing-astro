---
---
<div class="tweaks" id="tweaks" role="dialog" aria-label="Tweaks">
  <div class="tw-head">
    <span>Tweaks</span>
    <span class="tw-close" id="tweaksClose" role="button" aria-label="Close tweaks">×</span>
  </div>
  <div class="tw-body">
    <div class="tw-row">
      <label>Theme</label>
      <div class="tw-seg" id="twTheme">
        <button data-v="light">Light</button>
        <button data-v="dark">Dark</button>
      </div>
    </div>
    <div class="tw-row">
      <label>Mono font</label>
      <div class="tw-seg" id="twFont">
        <button data-v="IBM Plex Mono">Plex</button>
        <button data-v="JetBrains Mono">JetBrains</button>
        <button data-v="Geist Mono">Geist</button>
      </div>
    </div>
    <div class="tw-row">
      <label>Accent</label>
      <div class="tw-swatches" id="twAccent">
        <div class="tw-sw" data-v="mint"  style="background:#d6f5e3;border:1px solid #9ce0bd"></div>
        <div class="tw-sw" data-v="amber" style="background:#fef3c7;border:1px solid #fbd38d"></div>
        <div class="tw-sw" data-v="sky"   style="background:#dbeafe;border:1px solid #93c5fd"></div>
        <div class="tw-sw" data-v="rose"  style="background:#ffe1e7;border:1px solid #fab1c0"></div>
      </div>
    </div>
  </div>
</div>
