---
const groups = [
  {
    label: 'Languages & UI',
    items: [
      { name: 'TypeScript',        level: 'daily' },
      { name: 'JavaScript (ES6+)', level: 'daily' },
      { name: 'HTML5 / CSS3',      level: 'daily' },
      { name: 'Tailwind CSS',      level: 'production' },
      { name: 'SCSS / CSS-in-JS',  level: 'production' },
    ],
  },
  {
    label: 'Frameworks',
    items: [
      { name: 'React.js',           level: 'production' },
      { name: 'Next.js',            level: 'production' },
      { name: 'Vue.js',             level: 'production' },
      { name: 'Oruga / Buefy',      level: 'production' },
      { name: 'Bootstrap / jQuery', level: 'legacy' },
    ],
  },
  {
    label: 'Practice',
    items: [
      { name: 'WCAG 2.1 / ARIA',     level: 'core' },
      { name: 'Core Web Vitals / Lighthouse',      level: 'core' },
      { name: 'Jest / unit testing',  level: 'production' },
      { name: 'SonarQube',            level: 'audit' },
      { name: 'Component libraries',  level: 'authoring' },
    ],
  },
];
---
<section>
  <div class="card">
    <h3 class="card-title">Skills &amp; practice</h3>
    <p class="card-sub">What's in the toolbox, and how I tend to use it.</p>

    <div class="skills">
      {groups.map((g) => (
        <div class="skill-group">
          <span class="label">{g.label}</span>
          <ul>
            {g.items.map((item) => (
              <li>
                <span>{item.name}</span>
                <span class="lvl">{item.level}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
