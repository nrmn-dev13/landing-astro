---
---
<div
  id="preloader"
  role="progressbar"
  aria-label="Loading page"
  aria-valuemin="0"
  aria-valuemax="100"
  aria-valuenow="0"
>
  <div id="preloader-inner">
    <span id="preloader-count" aria-hidden="true">00</span>
    <div id="preloader-track" aria-hidden="true">
      <div id="preloader-bar"></div>
    </div>
  </div>
</div>

<style>
  #preloader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.7s cubic-bezier(0.76, 0, 0.24, 1);
  }
  #preloader.done {
    transform: translateY(-100%);
  }
  #preloader-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  #preloader-count {
    font-family: var(--font-mono);
    font-size: clamp(56px, 12vw, 112px);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--fg);
    line-height: 1;
    font-variant-numeric: tabular-nums;
    user-select: none;
  }
  #preloader-track {
    width: 140px;
    height: 1px;
    background: var(--border);
    position: relative;
    overflow: hidden;
  }
  #preloader-bar {
    position: absolute;
    inset-block: 0;
    left: 0;
    width: 100%;
    background: var(--fg);
    transform: scaleX(0);
    transform-origin: left;
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    #preloader {
      transition: none;
    }
  }
</style>

<script>
  const overlay = document.getElementById('preloader')!;
  const counter = document.getElementById('preloader-count')!;
  const bar = document.getElementById('preloader-bar')!;

  document.body.style.overflow = 'hidden';

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reducedMotion) {
    overlay.setAttribute('aria-valuenow', '100');
    overlay.setAttribute('hidden', '');
    document.body.style.overflow = '';
  } else {
    const DURATION = 1600;
    const start = performance.now();

    function easeInOut(t: number) {
      return t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
    }

    function tick(now: number) {
      const progress = Math.min((now - start) / DURATION, 1);
      const val = Math.round(easeInOut(progress) * 100);

      counter.textContent = val < 10 ? `0${val}` : `${val}`;
      bar.style.transform = `scaleX(${easeInOut(progress)})`;
      overlay.setAttribute('aria-valuenow', String(val));

      if (progress < 1) {
        requestAnimationFrame(tick);
      } else {
        counter.textContent = '100';
        bar.style.transform = 'scaleX(1)';
        overlay.setAttribute('aria-valuenow', '100');
        setTimeout(() => {
          overlay.classList.add('done');
          overlay.addEventListener('transitionend', () => {
            overlay.setAttribute('hidden', '');
            document.body.style.overflow = '';
          }, { once: true });
        }, 180);
      }
    }

    requestAnimationFrame(tick);
  }
</script>
