  { label: 'Companies',      num: '4',      note: 'SG, ID — gov & enterprise', accent: false },
  { label: 'Tenure now',     num: '4+ yrs', note: 'Xtremax · Jan 2022',       accent: false },
  { label: 'A11y target',    num: 'WCAG 2.1', note: 'applied consistently',   accent: true  },
];

