---
const stats = [
  { value: '7+ yrs',   label: 'experience', accent: false },
  { value: 'Bogor, ID', label: 'UTC+7',      accent: false },
  { value: 'Open',      label: 'to work',    accent: true  },
  { value: 'Xtremax',   label: 'currently',  accent: false },
];
---
<section class="hero">
  <h1 class="h-display">Build with care.</h1>
  <h2 class="h-sub">Norman Ramadhan</h2>
  <p class="lead">
    <strong>Frontend engineer, 7+ years</strong>, building responsive, accessible,
    high-performance web apps for government and enterprise clients across
    Southeast Asia. Specialised in React, Vue and Next.js. WCAG-compliant by
    default; Core Web Vitals as a habit.
  </p>

  <div class="stats">
    {stats.map((s) => (
      <div class={`stat${s.accent ? ' accent' : ''}`}>
        <span class="v">{s.value}</span>
        <span class="k">{s.label}</span>
      </div>
    ))}
  </div>
</section>
